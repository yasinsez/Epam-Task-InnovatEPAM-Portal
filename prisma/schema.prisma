datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUBMITTER
  EVALUATOR
  ADMIN
}

enum IdeaStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum FormFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  SINGLE_SELECT
  MULTI_SELECT
  CHECKBOX
  DATE
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique @db.VarChar(254)
  name                String?              @db.VarChar(255)
  passwordHash        String
  emailConfirmed      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastLoginAt         DateTime?
  role                UserRole             @default(SUBMITTER)
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  failedLoginAttempts FailedLoginAttempt[]
  authLogs               AuthLog[]
  ideas                  Idea[]
  evaluations            Evaluation[]
  formConfigurationsBy   FormConfiguration[]

  @@index([email])
  @@index([lastLoginAt])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  jwt          String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sessionToken])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
}

model FailedLoginAttempt {
  id        String   @id @default(cuid())
  userId    String
  attemptAt DateTime @default(now())
  reason    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptAt])
  @@index([attemptAt])
}

model AuthLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  status    String
  timestamp DateTime @default(now())
  ipAddress String?
  userAgent String?
  reason    String?
  metadata  Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@index([timestamp])
}

// Form configuration for dynamic submission fields
model FormConfiguration {
  id                   String               @id @default(cuid())
  updatedAt            DateTime             @updatedAt
  updatedById          String?
  updatedBy            User?                @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  formFieldDefinitions FormFieldDefinition[]

  @@index([updatedAt])
}

model FormFieldDefinition {
  id                     String            @id @default(cuid())
  formConfigurationId    String
  formConfiguration      FormConfiguration @relation(fields: [formConfigurationId], references: [id], onDelete: Cascade)
  label                  String            @db.VarChar(100)
  fieldType              FormFieldType
  required               Boolean           @default(false)
  displayOrder           Int               @default(0)
  options                Json?
  minValue               Float?
  maxValue               Float?
  maxLength              Int?

  @@index([formConfigurationId, displayOrder])
}

// Category model (new)
model Category {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(500)
  order       Int      @default(999)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ideas       Idea[]

  @@index([slug])
  @@index([isActive, order, name])
}

// Idea model (new)
model Idea {
  id                   String      @id @default(cuid())
  title                String      @db.VarChar(100)
  description          String      @db.Text
  sanitizedTitle       String      @db.VarChar(100)
  sanitizedDescription String      @db.Text
  categoryId           String
  category             Category    @relation(fields: [categoryId], references: [id])
  userId               String
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedAt          DateTime    @default(now())
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  status               IdeaStatus  @default(SUBMITTED)
  dynamicFieldValues   Json?
  attachment           Attachment?
  evaluation           Evaluation?

  @@index([userId])
  @@index([categoryId])
  @@index([submittedAt])
  @@index([userId, submittedAt])
}

// Evaluation model - one per idea when evaluated
model Evaluation {
  id            String   @id @default(cuid())
  ideaId        String   @unique
  idea          Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  decision      String   @db.VarChar(20) // "ACCEPTED" | "REJECTED"
  comments      String   @db.Text // 1-2000 chars
  evaluatorId   String?
  evaluator     User?    @relation(fields: [evaluatorId], references: [id], onDelete: SetNull)
  evaluatedAt   DateTime @default(now())

  @@index([evaluatorId])
}

// Attachment model - single file per idea
model Attachment {
  id               String   @id @default(cuid())
  ideaId           String   @unique
  idea             Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  originalFileName String   @db.VarChar(255)
  storedPath       String   @unique @db.VarChar(500)
  fileSizeBytes    Int
  mimeType         String   @db.VarChar(100)
  createdAt        DateTime @default(now())

  @@index([ideaId])
  @@index([storedPath])
}
